.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: white;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.content {
  padding: 30rpx;
}

.player {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}

.player-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.player-info {
  flex: 1;
}

.player-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
  color: #333;
}

.player-duration {
  font-size: 24rpx;
  color: #999;
}

.player-controls {
  display: flex;
  gap: 20rpx;
}

.control-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.control-icon {
  width: 30rpx;
  height: 30rpx;
}

.progress-bar {
  background-color: white;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}

.slider {
  width: 100%;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #333;
}

.audio-list {
  background-color: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.audio-item {
  display: flex;
  align-items: center;
  padding: 25rpx;
  border-bottom: 1rpx solid #eee;
  transition: background-color 0.2s ease;
}

.audio-item:hover {
  background-color: #f9f9f9;
}

.audio-item:last-child {
  border-bottom: none;
}

.audio-icon {
  width: 50rpx;
  height: 50rpx;
  margin-right: 20rpx;
}

.audio-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.play-icon {
  width: 30rpx;
  height: 30rpx;
}

.audio-item.upload {
  color: #4CAF50;
}

.audio-item.upload .audio-name {
  color: #4CAF50;
}

.empty-audio {
  padding: 60rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}