.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: white;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.content {
  padding: 30rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #333;
}

.emotion-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
}

.emotion-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  background-color: white;
  border: 2rpx solid #eee;
  transition: all 0.2s ease;
}

.emotion-btn:hover {
  border-color: #4CAF50;
  transform: translateY(-2rpx);
}

.emotion-btn.active {
  border-color: #4CAF50;
  background-color: #f0f9ff;
}

.emotion-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 10rpx;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  background-color: white;
  font-size: 28rpx;
  resize: none;
}

.input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  background-color: white;
  font-size: 28rpx;
}

.hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.submit-btn {
  width: 100%;
  padding: 25rpx;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: white;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: white;
  border-radius: 16rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 500rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  text-align: center;
  color: #333;
}

.modal-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  padding: 15rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.modal-btn.cancel {
  background-color: #f5f5f5;
  color: #333;
}

.modal-btn.confirm {
  background-color: #4CAF50;
  color: white;
}