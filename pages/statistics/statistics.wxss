.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: white;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.content {
  padding: 30rpx;
}

.stats-card {
  background-color: white;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}

.stats-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.stats-number {
  font-size: 60rpx;
  font-weight: bold;
  color: #4CAF50;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #333;
}

.chart-container {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.chart {
  width: 100%;
  height: 400rpx;
}

.record-list {
  background-color: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.record-item {
  padding: 25rpx;
  border-bottom: 1rpx solid #eee;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.record-emotion {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
  color: #333;
}

.record-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.record-lock {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.lock-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.empty-record {
  padding: 60rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}